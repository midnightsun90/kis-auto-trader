# 이 파일을 .env 로 복사한 뒤 값을 채우십시오. (.env는 절대 커밋하지 않음)

# 환경: paper(모의투자, 기본/권장) 또는 real(실전)
KIS_ENV=paper

# 안전장치: true면 실제 주문 API를 호출하지 않고 로그만 남김. 검증 끝나면 false.
KIS_DRY_RUN=true

# KIS Developers 포털에서 발급받은 키 (모의/실전 계좌별로 다름)
KIS_APPKEY=
KIS_APPSECRET=

# 계좌번호 8-2자리. 예) 계좌가 12345678-01 이면:
KIS_CANO=12345678
KIS_ACNT_PRDT_CD=01

# 실전 계좌에서 실제 주문을 허용하려면(매우 주의) yes 로 설정. 평소엔 비워둘 것.
KIS_ALLOW_REAL_ORDER=
